###############################################################################
# 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
###############################################################################

# 容器名称
COMPOSE_PROJECT_NAME=schedule-generator

# 端口配置（修改这里可更改访问端口）
APP_PORT=3080

# 时区设置
TZ=Asia/Shanghai

# 如果使用自定义镜像（非 Docker Hub 官方镜像）
# IMAGE_NAME=your-registry/schedule-generator
# IMAGE_TAG=latest
